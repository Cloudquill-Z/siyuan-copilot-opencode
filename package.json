{
  "name": "siyuan-copilot-opencode",
  "version": "3.1.36",
  "type": "module",
  "description": "Independent SiYuan OpenCode plugin for note-aware chat, tools, and local OpenCode workflows",
  "repository": "https://github.com/Cloudquill-Z/siyuan-copilot-opencode",
  "homepage": "https://github.com/Cloudquill-Z/siyuan-copilot-opencode",
  "author": "Cloudquill-Z",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development VITE_SOURCEMAP=inline vite build --watch",
    "build": "cross-env NODE_ENV=production vite build && node --no-warnings ./scripts/make_install.js",
    "make-link": "node --no-warnings ./scripts/make_dev_link.js",
    "make_dev_copy": "node --no-warnings ./scripts/make_dev_copy.js",
    "test:utils": "node --loader ts-node/esm scripts/test-utils.ts",
    "update-version": "node --no-warnings ./scripts/update_version.js",
    "make-install": "npm run build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@tsconfig/svelte": "^4.0.1",
    "@types/node": "^20.3.0",
    "cross-env": "^7.0.3",
    "fast-glob": "^3.2.12",
    "glob": "^10.0.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8",
    "rollup-plugin-livereload": "^2.0.5",
    "sass": "^1.63.3",
    "siyuan": "1.1.8",
    "svelte": "^4.2.19",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "vite": "^5.2.9",
    "vite-plugin-static-copy": "^1.0.2",
    "vite-plugin-zip-pack": "^1.0.5"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "katex": "^0.16.25"
  }
}